# Telegram
TELEGRAM_BOT_TOKEN=seu_token_aqui
OWNER_USER_ID=163177765
STAR_PRICE=1
BOT_MODE=polling
WEBHOOK_URL=
WEBHOOK_SECRET=

# Limits
MAX_VIDEO_SIZE_MB=50
DOWNLOAD_TIMEOUT_SECONDS=120
MAX_CONCURRENT_DOWNLOADS=3

# Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./downloads

# S3 (se STORAGE_TYPE=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# FFmpeg
FFMPEG_PATH=ffmpeg
ENABLE_COMPRESSION=true

# Instagram (instagrapi)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
# Código TOTP de 6 dígitos (só na 1ª vez; depois usa sessão salva)
INSTAGRAM_VERIFICATION_CODE=
INSTAGRAM_SESSION_PATH=./data/instagram_session.json
# Cookies para gallery-dl (opcional — veja README)
# Arquivo cookies.txt exportado do navegador (formato Netscape)
INSTAGRAM_COOKIES_PATH=
# Ou cookies direto do navegador: chrome, firefox, edge, etc.
INSTAGRAM_COOKIES_BROWSER=

# LLM — legenda para Reels do Instagram
OPENAI_API_KEY=
# Modelo com visão (gpt-4o recomendado)
OPENAI_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO
